<!-- Checkout Bottom Sheet Modal (Hidden by default) -->
<div id="checkout-modal" class="fixed inset-0 z-50 hidden">
  <div id="checkout-backdrop" class="absolute inset-0 bg-on-background/40 backdrop-blur-sm transition-opacity duration-300 opacity-0" onclick="confirmCloseCheckout()"></div>
  <div id="checkout-sheet" class="absolute bottom-0 left-0 right-0 max-w-4xl mx-auto bg-surface rounded-t-2xl shadow-[0_-8px_30px_rgba(0,0,0,0.12)] transform translate-y-full transition-transform duration-300 ease-out flex flex-col max-h-[90vh]">
    <div class="w-full flex justify-center pt-3 pb-2">
      <div class="w-12 h-1.5 bg-outline-variant rounded-full"></div>
    </div>
    <div class="px-6 pb-8 overflow-y-auto" id="checkout-content">
      <!-- Injected by JavaScript -->
    </div>
  </div>
</div>
