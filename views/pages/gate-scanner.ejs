<%- include('../partials/header') %>
<script src="https://unpkg.com/html5-qrcode" type="text/javascript"></script>
<script>
  if (!localStorage.getItem('adminToken')) {
    window.location.href = '/admin/login';
  }
</script>

<div class="max-w-xl mx-auto py-8 px-4">
  <div class="text-center mb-8">
    <h1 class="text-headline-md font-extrabold tracking-tight mb-2">Scanner Gerbang</h1>
    <p class="text-body-md text-on-surface-variant">Pindai kode QR pengunjung untuk membuka palang parkir.</p>
  </div>
  
  <div class="bg-surface p-6 md:p-8 rounded-3xl shadow-xl shadow-slate-200/50 border border-surface-container-high relative overflow-hidden">
    
    <!-- Gate Location Selector -->
    <div class="mb-6 relative z-10">
      <label class="block text-label-md font-bold mb-2 text-on-surface">Pilih Lokasi Gerbang (Kamera Ini)</label>
      <select id="gate-location" class="w-full px-5 py-4 bg-surface-dim border border-outline-variant rounded-2xl focus:outline-none focus:ring-2 focus:ring-primary/40 font-bold text-on-surface appearance-none cursor-pointer">
        <option value="">Memuat gedung...</option>
      </select>
    </div>

    <!-- Scanner Viewfinder -->
    <div id="scanner-container" class="hidden mb-6">
      <div class="rounded-2xl overflow-hidden border-2 border-primary/20 relative bg-black">
        <div id="reader" width="100%"></div>
      </div>
      <p class="text-center mt-3 text-sm text-on-surface-variant">Arahkan kamera ke layar HP pengunjung</p>
    </div>

    <button id="btn-start" onclick="startScanner()" class="w-full bg-primary text-on-primary py-4 rounded-full font-bold shadow-md shadow-blue-500/30 active:scale-95 transition-all text-lg mb-4">
      Nyalakan Kamera Scanner
    </button>
    <button id="btn-stop" onclick="stopScanner()" class="hidden w-full bg-error-container text-error hover:bg-error hover:text-white py-4 rounded-full font-bold transition-colors text-lg mb-4">
      Matikan Kamera
    </button>

    <!-- Result Display -->
    <div id="gate-result" class="hidden rounded-2xl p-5 text-center flex flex-col items-center justify-center min-h-[120px] transition-all">
      <div id="res-icon" class="text-4xl mb-2"></div>
      <div id="res-text" class="text-title-md font-bold"></div>
    </div>
  </div>
</div>

<style>
/* Override default html5-qrcode styles to match our design */
#reader__dashboard_section_csr button {
  background: var(--color-surface-dim);
  border: 1px solid var(--color-outline-variant);
  border-radius: 0.5rem;
  padding: 0.5rem 1rem;
  font-weight: 600;
  cursor: pointer;
  margin: 0.25rem;
}
#reader__dashboard_section_swaplink {
  color: var(--color-primary);
  text-decoration: none;
  font-weight: 600;
}
#reader video {
  border-radius: 1rem;
}
</style>

<script>
let html5QrcodeScanner;
let isProcessing = false;

async function loadLocations() {
  try {
    const res = await axios.get('/api/locations');
    const select = document.getElementById('gate-location');
    select.innerHTML = '<option value="">-- Silakan Pilih Lokasi Gerbang --</option>';
    res.data.forEach(loc => {
      select.innerHTML += `<option value="${loc._id}">${loc.name}</option>`;
    });
    
    // Auto-select if a locationId is passed in URL (e.g. for kiosk mode)
    const urlParams = new URLSearchParams(window.location.search);
    const locId = urlParams.get('locationId');
    if (locId) {
      select.value = locId;
    }
  } catch (e) {
    document.getElementById('gate-location').innerHTML = '<option value="">Gagal memuat gedung</option>';
  }
}
loadLocations();

function startScanner() {
  const locId = document.getElementById('gate-location').value;
  if (!locId) {
    alert("Mohon pilih Lokasi Gerbang terlebih dahulu!");
    return;
  }

  document.getElementById('btn-start').classList.add('hidden');
  document.getElementById('btn-stop').classList.remove('hidden');
  document.getElementById('scanner-container').classList.remove('hidden');
  document.getElementById('gate-result').classList.add('hidden');

  if (!html5QrcodeScanner) {
    html5QrcodeScanner = new Html5Qrcode("reader");
  }

  const config = { fps: 10, qrbox: { width: 250, height: 250 } };

  html5QrcodeScanner.start(
    { facingMode: "environment" },
    config,
    onScanSuccess,
    onScanFailure
  ).catch(err => {
    alert("Gagal mengakses kamera. Pastikan memberikan izin akses.");
    stopScanner();
  });
}

function stopScanner() {
  if (html5QrcodeScanner) {
    const state = html5QrcodeScanner.getState();
    // State 2: SCANNING, State 3: PAUSED
    if (state === 2 || state === 3) {
      html5QrcodeScanner.stop().then(() => {
        html5QrcodeScanner.clear();
      }).catch(e => console.log("Stop error:", e));
    } else {
      html5QrcodeScanner.clear();
    }
  }
  document.getElementById('btn-start').classList.remove('hidden');
  document.getElementById('btn-stop').classList.add('hidden');
  document.getElementById('scanner-container').classList.add('hidden');
  document.getElementById('gate-result').classList.add('hidden');
  isProcessing = false;
}

async function onScanSuccess(decodedText, decodedResult) {
  if (isProcessing) return; // Prevent double scan
  
  const locId = document.getElementById('gate-location').value;
  if (!locId) return;

  isProcessing = true;
  
  // Pause scanning instead of turning off camera completely
  if (html5QrcodeScanner && html5QrcodeScanner.getState() === 2) {
    html5QrcodeScanner.pause();
  }

  const resultEl = document.getElementById('gate-result');
  const resIcon = document.getElementById('res-icon');
  const resText = document.getElementById('res-text');

  resultEl.className = 'rounded-2xl p-5 text-center flex flex-col items-center justify-center min-h-[120px] transition-all bg-surface-dim animate-pulse mb-6';
  resIcon.innerHTML = '⏳';
  resText.innerHTML = 'Memvalidasi...';
  resText.className = 'text-title-md font-bold text-on-surface-variant';
  resultEl.classList.remove('hidden');

  try {
    const res = await axios.post('/api/gate/check-in', {
      qrCodeData: decodedText,
      gateLocationId: locId
    });
    
    // SUCCESS
    resultEl.className = 'rounded-2xl p-5 text-center flex flex-col items-center justify-center min-h-[120px] transition-all bg-primary-container text-on-primary-container shadow-inner border border-primary/20 scale-105 mb-6';
    resIcon.innerHTML = '✅';
    resText.innerHTML = res.data.message;
    resText.className = 'text-title-md font-bold';
    
    // Resume scanner after 3 seconds
    setTimeout(() => {
      if (html5QrcodeScanner && html5QrcodeScanner.getState() === 3) {
        html5QrcodeScanner.resume();
      }
      resultEl.classList.add('hidden');
      isProcessing = false;
    }, 3000);

  } catch(e) {
    // FAILED
    resultEl.className = 'rounded-2xl p-5 text-center flex flex-col items-center justify-center min-h-[120px] transition-all bg-error-container text-on-error-container shadow-inner border border-error/20 scale-105 mb-6';
    resIcon.innerHTML = '❌';
    resText.innerHTML = e.response?.data?.error || "Gagal memvalidasi QR Code";
    resText.className = 'text-title-md font-bold';
    
    setTimeout(() => {
      if (html5QrcodeScanner && html5QrcodeScanner.getState() === 3) {
        html5QrcodeScanner.resume();
      }
      resultEl.classList.add('hidden');
      isProcessing = false;
    }, 3000);
  }
}

function onScanFailure(error) {
  // Ignored. Continuously fails until a QR is found.
}
</script>
<%- include('../partials/footer') %>
