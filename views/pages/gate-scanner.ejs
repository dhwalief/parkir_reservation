<%- include('../partials/header') %>
<div class="max-w-md mx-auto">
  <h1 class="text-headline-md mb-6">Simulator Scanner Gerbang</h1>
  
  <div class="bg-surface p-6 rounded-2xl shadow-sm border border-outline-variant">
    <div class="mb-4">
      <label class="block text-label-md font-bold mb-2">Location ID Gerbang Ini</label>
      <input type="text" id="gate-location" class="w-full px-4 py-3 bg-surface-dim border border-outline-variant rounded-xl font-mono text-sm" placeholder="Contoh: 64b8f... (ID Gedung A)">
      <p class="text-body-sm text-on-surface-variant mt-2">Dalam produksi, ID ini tertanam statis di perangkat IoT/kamera gerbang.</p>
    </div>

    <div class="mb-6">
      <label class="block text-label-md font-bold mb-2">Hasil Scan QR (Reservation ID)</label>
      <input type="text" id="gate-qr" class="w-full px-4 py-3 bg-surface-dim border border-outline-variant rounded-xl font-mono text-sm" placeholder="Teks QR dari HP Pengguna">
    </div>

    <button onclick="simulateScan()" class="w-full bg-primary text-on-primary py-4 rounded-xl font-bold text-title-md shadow-md active:scale-95 transition-transform">
      SIMULASIKAN SCAN
    </button>

    <div id="gate-result" class="mt-6 hidden rounded-xl p-4 text-center font-bold text-title-md"></div>
  </div>
</div>

<script>
async function simulateScan() {
  const locId = document.getElementById('gate-location').value.trim();
  const resId = document.getElementById('gate-qr').value.trim();
  const resultEl = document.getElementById('gate-result');

  if(!locId || !resId) {
    alert("Isi Location ID dan QR Text");
    return;
  }

  resultEl.classList.remove('hidden', 'bg-error-container', 'text-on-error-container', 'bg-primary-container', 'text-on-primary-container');
  resultEl.innerHTML = "Memproses...";
  resultEl.classList.remove('hidden');

  try {
    const res = await axios.post('/api/gate/scan', {
      locationId: locId,
      reservationId: resId
    });
    
    resultEl.classList.add('bg-primary-container', 'text-on-primary-container');
    resultEl.innerHTML = "✅ " + res.data.message;
  } catch(e) {
    resultEl.classList.add('bg-error-container', 'text-on-error-container');
    resultEl.innerHTML = "❌ " + (e.response?.data?.error || "Terjadi kesalahan sistem");
  }
}
</script>
<%- include('../partials/footer') %>
