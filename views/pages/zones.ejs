<%- include('../partials/header') %>

<div class="mb-6 flex items-center">
  <a href="/" class="mr-4 p-2 bg-surface-dim rounded-full text-on-surface-variant hover:bg-surface-container transition-colors">
    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
    </svg>
  </a>
  <div>
    <h1 class="text-headline-lg text-on-background"><%= location.name %></h1>
    <p class="text-body-md text-on-surface-variant"><%= location.address %></p>
  </div>
</div>

<div id="zones-container" class="space-y-4">
  <div class="flex justify-center items-center h-32">
    <div class="animate-spin rounded-full h-8 w-8 border-4 border-primary border-t-transparent"></div>
  </div>
</div>

<%- include('../partials/checkout-modal') %>

<script>
const locationId = '<%= location._id %>';

async function fetchZones() {
  try {
    const res = await axios.get('/api/locations/' + locationId + '/zones');
    const zones = res.data;
    
    let html = '';
    zones.forEach(zone => {
      const available = zone.total_capacity - zone.active_reservations - zone.active_occupants;
      const isAvailable = available > 0;
      
      html += `
        <div class="bg-surface rounded-2xl p-5 border ${isAvailable ? 'border-primary/30' : 'border-error/30'} flex justify-between items-center shadow-sm">
          <div>
            <h4 class="text-title-lg font-bold text-on-surface">${zone.name}</h4>
            <p class="text-body-sm text-on-surface-variant mt-1">Lantai: ${zone.floor_level}</p>
          </div>
          <div class="text-right flex flex-col items-end">
            <span class="text-headline-md font-black ${isAvailable ? 'text-primary' : 'text-error'} mb-2">${isAvailable ? available : 'Penuh'}</span>
            <button 
              ${!isAvailable ? 'disabled' : ''} 
              onclick="openCheckout('${zone._id}', '${zone.name}', ${available})"
              class="${isAvailable ? 'bg-primary text-on-primary shadow-md hover:bg-primary/90' : 'bg-surface-container-highest text-on-surface-variant cursor-not-allowed'} px-6 py-2.5 rounded-full font-bold text-label-lg transition-all active:scale-95">
              ${isAvailable ? 'Pesan' : 'Habis'}
            </button>
          </div>
        </div>
      `;
    });
    document.getElementById('zones-container').innerHTML = html;
  } catch (err) {
    document.getElementById('zones-container').innerHTML = '<div class="p-4 bg-error-container text-on-error-container rounded-2xl">Gagal memuat zona.</div>';
  }
}

// Checkout Modal Logic
let currentHoldId = null;
let countdownInterval = null;

async function openCheckout(zoneId, zoneName, availableCount) {
  const modal = document.getElementById('checkout-modal');
  const sheet = document.getElementById('checkout-sheet');
  const backdrop = document.getElementById('checkout-backdrop');
  const content = document.getElementById('checkout-content');

  modal.classList.remove('hidden');
  setTimeout(() => {
    backdrop.classList.remove('opacity-0');
    sheet.classList.remove('translate-y-full');
  }, 10);

  content.innerHTML = `
    <div class="flex justify-center items-center py-8">
      <div class="animate-spin rounded-full h-8 w-8 border-4 border-primary border-t-transparent"></div>
    </div>
  `;

  try {
    const holdRes = await axios.post('/api/reservations/hold', {
      locationId: locationId,
      zoneId: zoneId
    });
    
    currentHoldId = holdRes.data.reservationId;
    const expiresAt = new Date(holdRes.data.holdExpiresAt).getTime();

    content.innerHTML = `
      <div class="flex justify-between items-start mb-6">
        <div>
          <h2 class="text-headline-sm font-bold text-on-surface">Detail Kendaraan</h2>
          <p class="text-body-md text-on-surface-variant">Selesaikan pesanan untuk <b>${zoneName}</b></p>
        </div>
        <div class="bg-error-container text-on-error-container px-3 py-1.5 rounded-lg flex items-center font-mono font-bold text-lg">
          <svg class="w-5 h-5 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span id="hold-timer">02:00</span>
        </div>
      </div>

      <div class="space-y-5">
        <div>
          <label class="block text-label-md font-bold text-on-surface mb-2">Plat Nomor Kendaraan</label>
          <input type="text" id="license-plate" class="w-full px-4 py-3.5 bg-surface-dim border border-outline-variant rounded-xl focus:ring-2 focus:ring-primary focus:border-primary transition-all text-title-md uppercase font-mono tracking-wider" placeholder="B 1234 ABC">
        </div>
        
        <div>
          <label class="block text-label-md font-bold text-on-surface mb-2">Masuk dengan (Lazy Auth)</label>
          <input type="text" id="phone-number" class="w-full px-4 py-3.5 bg-surface-dim border border-outline-variant rounded-xl focus:ring-2 focus:ring-primary focus:border-primary transition-all text-title-md mb-4" placeholder="Nomor WhatsApp (08...)">
          <div class="flex gap-3">
            <button onclick="confirmCloseCheckout()" class="w-1/3 bg-surface-container hover:bg-surface-variant text-on-surface py-4 rounded-xl font-bold text-title-md transition-all active:scale-95 shadow-sm border border-outline-variant/50">
              Batal
            </button>
            <button onclick="confirmCheckout()" class="w-2/3 bg-[#25D366] hover:bg-[#20bd5a] text-white py-4 rounded-xl font-bold text-title-md flex items-center justify-center transition-all active:scale-95 shadow-md">
              <svg class="w-6 h-6 mr-2" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.571-.012c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
              Bayar
            </button>
          </div>
        </div>
        <p class="text-body-sm text-center text-on-surface-variant px-4">
          Dengan melanjutkan, Anda menyetujui bahwa reservasi akan hangus otomatis jika Anda tidak tiba dalam 15 menit.
        </p>
      </div>
    `;

    startHoldTimer(expiresAt);

  } catch (err) {
    content.innerHTML = `
      <div class="text-center py-6">
        <div class="text-error mb-4"><svg class="w-16 h-16 mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg></div>
        <h3 class="text-title-lg font-bold mb-2">Gagal Menahan Kuota</h3>
        <p class="text-body-md text-on-surface-variant mb-6">${err.response?.data?.error || 'Zona mungkin sudah penuh.'}</p>
        <button onclick="closeCheckout()" class="bg-surface-dim px-6 py-2 rounded-full font-bold">Kembali</button>
      </div>
    `;
  }
}

function startHoldTimer(expiresAt) {
  clearInterval(countdownInterval);
  const timerEl = document.getElementById('hold-timer');
  
  countdownInterval = setInterval(() => {
    const now = new Date().getTime();
    const distance = expiresAt - now;

    if (distance <= 0) {
      clearInterval(countdownInterval);
      if(timerEl) timerEl.innerHTML = "00:00";
      closeCheckout();
      fetchZones(); // Refresh zones
      return;
    }

    const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
    const seconds = Math.floor((distance % (1000 * 60)) / 1000);
    if(timerEl) timerEl.innerHTML = `${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;
  }, 1000);
}

function closeCheckout() {
  const sheet = document.getElementById('checkout-sheet');
  const backdrop = document.getElementById('checkout-backdrop');
  
  sheet.classList.add('translate-y-full');
  backdrop.classList.add('opacity-0');
  
  setTimeout(() => {
    document.getElementById('checkout-modal').classList.add('hidden');
    clearInterval(countdownInterval);
    currentHoldId = null;
  }, 300);
}

function confirmCloseCheckout() {
  if (!currentHoldId) {
    closeCheckout();
    return;
  }
  if (confirm("Anda sedang mengisi formulir pemesanan. Yakin ingin membatalkannya? Waktu Anda akan terus berjalan hingga kadaluwarsa.")) {
    closeCheckout();
  }
}

async function confirmCheckout() {
  const licensePlate = document.getElementById('license-plate').value.trim();
  const phoneNumber = document.getElementById('phone-number').value.trim();
  
  if(!licensePlate || !phoneNumber) {
    alert("Plat nomor dan Nomor WhatsApp wajib diisi");
    return;
  }

  const platRegex = /^[a-zA-Z]{1,2}\s\d{1,4}\s[a-zA-Z]{1,3}$/;
  if(!platRegex.test(licensePlate)) {
    alert("Format plat nomor tidak valid (contoh yang benar: B 1234 ABC)");
    return;
  }

  const phoneRegex = /^(08|628)\d{7,12}$/;
  if(!phoneRegex.test(phoneNumber)) {
    alert("Format Nomor HP tidak valid (harus diawali 08 atau 628 dan panjang 9-15 digit)");
    return;
  }

  try {
    const res = await axios.post('/api/reservations/confirm', {
      reservationId: currentHoldId,
      licensePlate,
      phoneNumber
    });
    
    localStorage.setItem('parkir_phone', phoneNumber);
    window.location.href = '/ticket/' + res.data._id;
  } catch(e) {
    alert(e.response?.data?.error || "Gagal mengkonfirmasi tiket");
  }
}

fetchZones();
</script>

<%- include('../partials/footer') %>
