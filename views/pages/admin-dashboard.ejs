<%- include('../partials/header') %>
<div class="max-w-4xl mx-auto py-8 px-4">
  <div class="flex justify-between items-center mb-8">
    <h1 class="text-headline-md font-extrabold tracking-tight">Panel Kendali Kuota</h1>
    <a href="/" class="px-4 py-2 bg-surface-dim text-on-surface rounded-full text-sm font-bold hover:bg-surface-variant transition-colors">Keluar</a>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <div class="bg-primary-container text-on-primary-container p-6 rounded-2xl shadow-sm">
      <div class="text-label-md uppercase tracking-wider mb-2 font-bold">Reservasi Aktif</div>
      <div id="stat-active" class="text-display-md font-black">...</div>
    </div>
    <div class="bg-secondary-container text-on-secondary-container p-6 rounded-2xl shadow-sm">
      <div class="text-label-md uppercase tracking-wider mb-2 font-bold">Kendaraan di Dalam</div>
      <div id="stat-occupants" class="text-display-md font-black">...</div>
    </div>
    <div class="bg-error-container text-on-error-container p-6 rounded-2xl shadow-sm">
      <div class="text-label-md uppercase tracking-wider mb-2 font-bold">Anomali Dilaporkan</div>
      <div id="stat-anomalies" class="text-display-md font-black">...</div>
    </div>
  </div>

  <h2 class="text-title-lg font-bold mb-4">Manajemen Zona (Manual Override)</h2>
  <div class="bg-surface rounded-2xl border border-outline-variant overflow-hidden overflow-x-auto shadow-sm">
    <table class="w-full text-left min-w-[600px]">
      <thead class="bg-surface-dim border-b border-outline-variant">
        <tr>
          <th class="p-4 font-bold text-label-lg">Gedung / Zona</th>
          <th class="p-4 font-bold text-label-lg text-center">Kapasitas Sisa</th>
          <th class="p-4 font-bold text-label-lg text-right">Aksi Darurat</th>
        </tr>
      </thead>
      <tbody id="zones-table-body">
        <tr><td colspan="3" class="text-center py-8 text-on-surface-variant">Memuat data...</td></tr>
      </tbody>
    </table>
  </div>
</div>

<script>
async function loadDashboard() {
  try {
    const statsRes = await axios.get('/api/admin/stats');
    document.getElementById('stat-active').innerText = statsRes.data.active_reservations;
    document.getElementById('stat-occupants').innerText = statsRes.data.occupants;
    document.getElementById('stat-anomalies').innerText = statsRes.data.anomalies;

    const zonesRes = await axios.get('/api/admin/zones');
    let html = '';
    zonesRes.data.forEach(z => {
      const available = z.total_capacity - z.active_reservations - z.active_occupants;
      html += `
        <tr class="border-b border-outline-variant/30 hover:bg-surface-dim/30 transition-colors">
          <td class="p-4">
            <div class="text-body-lg font-bold">${z.locationId?.name || '-'}</div>
            <div class="text-body-sm text-on-surface-variant">${z.name} (Lantai: ${z.floor_level})</div>
          </td>
          <td class="p-4 text-center">
            <span class="${available > 0 ? 'bg-primary-container text-on-primary-container' : 'bg-error-container text-on-error-container'} px-3 py-1.5 rounded-full font-bold text-sm">
              ${available} / ${z.total_capacity}
            </span>
          </td>
          <td class="p-4 text-right">
            <button onclick="overrideZone('${z._id}')" ${z.total_capacity === 0 ? 'disabled' : ''} class="${z.total_capacity === 0 ? 'bg-surface-variant text-on-surface-variant cursor-not-allowed' : 'bg-error hover:bg-error/90 text-white active:scale-95'} px-4 py-2 font-bold rounded-lg text-sm transition-all shadow-sm">
              ${z.total_capacity === 0 ? 'Ditutup' : 'Tutup Paksa'}
            </button>
          </td>
        </tr>
      `;
    });
    document.getElementById('zones-table-body').innerHTML = html;
  } catch(e) {
    console.error("Gagal memuat dasbor admin", e);
  }
}

async function overrideZone(zoneId) {
  if(confirm("PERINGATAN: Aksi ini akan mengubah kapasitas total zona ini menjadi 0 (menutup area dari pesanan baru selamanya). Anda yakin?")) {
    try {
      await axios.post('/api/admin/zones/' + zoneId + '/override');
      alert("Zona berhasil ditutup paksa.");
      loadDashboard();
    } catch(e) {
      alert("Gagal melakukan override.");
    }
  }
}

loadDashboard();
setInterval(loadDashboard, 10000); // Polling every 10s
</script>
<%- include('../partials/footer') %>
