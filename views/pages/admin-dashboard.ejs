<%- include('../partials/header') %>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<div class="mb-8 flex justify-between items-end">
  <div>
    <h1 class="text-headline-xl-mobile md:text-headline-xl text-on-background mb-2">Panel Admin</h1>
    <p class="text-body-md text-on-surface-variant">Kelola kapasitas, tarif, dan inventaris gedung.</p>
  </div>
</div>

<!-- Tab Navigation (Mirip Filter Chips) -->
<div class="flex space-x-2 overflow-x-auto pb-4 mb-6 scrollbar-hide" id="admin-tabs">
  <button onclick="switchTab('tab-home')" id="btn-tab-home" class="sidebar-btn px-6 py-3 rounded-full font-bold transition-all bg-primary-container text-on-primary-container shrink-0 text-sm md:text-base">Ringkasan</button>
  <button onclick="switchTab('tab-locations')" id="btn-tab-locations" class="sidebar-btn px-6 py-3 rounded-full font-bold transition-all bg-surface border border-outline-variant text-on-surface hover:bg-surface-dim shrink-0 text-sm md:text-base">Gedung Induk</button>
  <button onclick="switchTab('tab-zones')" id="btn-tab-zones" class="sidebar-btn px-6 py-3 rounded-full font-bold transition-all bg-surface border border-outline-variant text-on-surface hover:bg-surface-dim shrink-0 text-sm md:text-base">Zona Parkir</button>
</div>

<!-- TAB: HOME -->
<div id="tab-home" class="tab-content block animate-fade-in space-y-4">
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <div class="bg-surface rounded-2xl shadow-xl shadow-slate-200/50 p-5 border border-surface-container-high flex flex-col justify-between">
      <div class="text-label-md uppercase tracking-wider mb-4 font-bold text-on-surface-variant">Reservasi Aktif</div>
      <div id="stat-active" class="text-headline-xl font-black text-primary">0</div>
    </div>
    <div class="bg-surface rounded-2xl shadow-xl shadow-slate-200/50 p-5 border border-surface-container-high flex flex-col justify-between">
      <div class="text-label-md uppercase tracking-wider mb-4 font-bold text-on-surface-variant">Kendaraan Masuk</div>
      <div id="stat-occupants" class="text-headline-xl font-black text-secondary">0</div>
    </div>
    <div class="bg-surface rounded-2xl shadow-xl shadow-slate-200/50 p-5 border border-surface-container-high flex flex-col justify-between">
      <div class="text-label-md uppercase tracking-wider mb-4 font-bold text-on-surface-variant">Kendala (Penuh)</div>
      <div id="stat-anomalies" class="text-headline-xl font-black text-error">0</div>
    </div>
  </div>
</div>

<!-- TAB: LOCATIONS -->
<div id="tab-locations" class="tab-content hidden animate-fade-in space-y-8">
  <!-- Form Tambah Lokasi (Sama dengan input pencarian Home) -->
  <!-- Form Tambah Lokasi -->
  <div class="bg-surface rounded-2xl shadow-xl shadow-slate-200/50 p-6 border border-surface-container-high">
    <h3 class="text-title-lg font-bold mb-4 text-on-surface">Tambah Gedung Baru</h3>
    
    <!-- OSM Map Picker -->
    <div class="mb-6">
      <div class="flex gap-2 mb-2">
        <input type="text" id="map-search" placeholder="Cari nama lokasi (Mis: Monas, Jakarta)..." class="flex-1 px-4 py-3 bg-surface-dim border border-outline-variant rounded-xl focus:outline-none focus:ring-2 focus:ring-primary/40 font-bold text-on-surface text-sm">
        <button onclick="searchMap()" class="px-5 py-3 bg-secondary text-on-secondary font-bold rounded-xl shadow-sm hover:shadow-md transition-all text-sm shrink-0">Cari Peta</button>
      </div>
      <!-- z-index dipastikan agar tooltip leaflet tidak tertutup -->
      <div id="mapPicker" class="w-full h-[350px] rounded-xl border border-outline-variant z-10"></div>
      <p class="text-xs text-on-surface-variant mt-2">*Klik lokasi pada peta untuk mengisi otomatis form Latitude & Longitude di bawah.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <input type="text" id="loc-name" placeholder="Nama Gedung (Mis: Mall ABC)" class="w-full px-4 py-4 bg-surface-dim border border-outline-variant rounded-2xl focus:outline-none focus:ring-2 focus:ring-primary/40 focus:border-primary transition-all text-body-lg">
      <input type="text" id="loc-address" placeholder="Alamat Lengkap" class="w-full px-4 py-4 bg-surface-dim border border-outline-variant rounded-2xl focus:outline-none focus:ring-2 focus:ring-primary/40 focus:border-primary transition-all text-body-lg">
      <input type="number" id="loc-lat" placeholder="Latitude (Mis: -6.20)" class="w-full px-4 py-4 bg-surface-dim border border-outline-variant rounded-2xl focus:outline-none focus:ring-2 focus:ring-primary/40 focus:border-primary transition-all text-body-lg">
      <input type="number" id="loc-lng" placeholder="Longitude (Mis: 106.81)" class="w-full px-4 py-4 bg-surface-dim border border-outline-variant rounded-2xl focus:outline-none focus:ring-2 focus:ring-primary/40 focus:border-primary transition-all text-body-lg">
      <input type="number" id="loc-radius" placeholder="Radius Cari (Meter, Default: 5000)" class="w-full px-4 py-4 bg-surface-dim border border-outline-variant rounded-2xl focus:outline-none focus:ring-2 focus:ring-primary/40 focus:border-primary transition-all text-body-lg md:col-span-2">
      <button onclick="createLocation()" class="md:col-span-2 w-full py-4 bg-primary text-on-primary rounded-full font-bold shadow-md shadow-blue-500/30 active:scale-95 transition-all text-lg">Simpan Gedung</button>
    </div>
  </div>

  <div class="space-y-4" id="locations-list-body">
    <!-- Diisi via JS -->
  </div>
</div>

<!-- TAB: ZONES -->
<div id="tab-zones" class="tab-content hidden animate-fade-in space-y-8">
  <!-- Form Tambah Zona -->
  <div class="bg-surface rounded-2xl shadow-xl shadow-slate-200/50 p-6 border border-surface-container-high">
    <h3 class="text-title-lg font-bold mb-4 text-on-surface">Buka Area / Zona Baru</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <select id="zone-location" class="w-full px-4 py-4 bg-surface-dim border border-outline-variant rounded-2xl focus:outline-none focus:ring-2 focus:ring-primary/40 focus:border-primary transition-all text-body-lg md:col-span-2 font-bold text-on-surface appearance-none cursor-pointer">
        <option value="">-- Pilih Gedung Induk --</option>
      </select>
      <input type="text" id="zone-name" placeholder="Nama Zona (Mis: Premium, Reguler)" class="w-full px-4 py-4 bg-surface-dim border border-outline-variant rounded-2xl focus:outline-none focus:ring-2 focus:ring-primary/40 focus:border-primary transition-all text-body-lg">
      <input type="text" id="zone-floor" placeholder="Kode Lantai (Mis: B1)" class="w-full px-4 py-4 bg-surface-dim border border-outline-variant rounded-2xl focus:outline-none focus:ring-2 focus:ring-primary/40 focus:border-primary transition-all text-body-lg">
      <input type="number" id="zone-cap" placeholder="Kapasitas Maksimal (Unit)" class="w-full px-4 py-4 bg-surface-dim border border-outline-variant rounded-2xl focus:outline-none focus:ring-2 focus:ring-primary/40 focus:border-primary transition-all text-body-lg">
      <input type="number" id="zone-price" placeholder="Tarif Sewa (Rp/Jam)" class="w-full px-4 py-4 bg-surface-dim border border-outline-variant rounded-2xl focus:outline-none focus:ring-2 focus:ring-primary/40 focus:border-primary transition-all text-body-lg">
      <button onclick="createZone()" class="md:col-span-2 w-full py-4 bg-secondary text-on-secondary rounded-full font-bold shadow-md shadow-green-500/30 active:scale-95 transition-all text-lg">Terbitkan Zona</button>
    </div>
  </div>

  <div class="space-y-4" id="zones-list-body">
    <!-- Diisi via JS -->
  </div>
</div>

<script>
// ================= STATE & TABS =================
let locationsData = [];
let zonesData = [];

function switchTab(tabId) {
  // Sembunyikan semua konten
  document.querySelectorAll('.tab-content').forEach(el => el.classList.add('hidden'));
  document.getElementById(tabId).classList.remove('hidden');
  
  // Ubah gaya tab yang aktif
  document.querySelectorAll('.sidebar-btn').forEach(btn => {
    btn.className = "sidebar-btn px-6 py-3 rounded-full font-bold transition-all bg-surface border border-outline-variant text-on-surface hover:bg-surface-dim shrink-0 text-sm md:text-base";
  });
  const activeBtn = document.getElementById('btn-' + tabId);
  if(activeBtn) {
    activeBtn.className = "sidebar-btn px-6 py-3 rounded-full font-bold transition-all bg-primary-container text-on-primary-container shrink-0 text-sm md:text-base border border-primary-container";
  }

  if(tabId === 'tab-home') loadStats();
  if(tabId === 'tab-locations') {
    loadLocations();
    setTimeout(() => {
      initMap();
      if(map) map.invalidateSize();
    }, 100);
  }
  if(tabId === 'tab-zones') loadZones();
}

// ================= OSM LEAFLET MAP =================
let map, marker;
function initMap() {
  if (map) return; // Prevent double initialization
  
  // Default view: Jakarta
  map = L.map('mapPicker').setView([-6.2088, 106.8456], 12);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '&copy; OpenStreetMap contributors'
  }).addTo(map);

  map.on('click', function(e) {
    const lat = e.latlng.lat.toFixed(6);
    const lng = e.latlng.lng.toFixed(6);
    
    if (marker) map.removeLayer(marker);
    marker = L.marker([lat, lng]).addTo(map);
    
    document.getElementById('loc-lat').value = lat;
    document.getElementById('loc-lng').value = lng;
    
    // Reverse Geocoding (Autofill Address if empty)
    axios.get(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lng}`)
      .then(res => {
         if(res.data && res.data.display_name && !document.getElementById('loc-address').value) {
            document.getElementById('loc-address').value = res.data.display_name;
         }
      }).catch(e => console.warn("Geocoding failed"));
  });
}

async function searchMap() {
  const query = document.getElementById('map-search').value.trim();
  if(!query) return;
  try {
    const res = await axios.get(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(query)}`);
    if(res.data && res.data.length > 0) {
      const lat = parseFloat(res.data[0].lat);
      const lon = parseFloat(res.data[0].lon);
      map.flyTo([lat, lon], 16);
    } else {
      alert("Lokasi tidak ditemukan di OpenStreetMap.");
    }
  } catch(e) {
    alert("Gagal mencari lokasi.");
  }
}

// ================= API CALLS =================
async function loadStats() {
  try {
    const res = await axios.get('/api/admin/stats');
    document.getElementById('stat-active').innerText = res.data.active_reservations;
    document.getElementById('stat-occupants').innerText = res.data.occupants;
    document.getElementById('stat-anomalies').innerText = res.data.anomalies;
  } catch(e) {}
}

async function loadLocations() {
  try {
    const res = await axios.get('/api/admin/locations');
    locationsData = res.data;
    renderLocations();
    updateLocationDropdown();
  } catch(e) {}
}

async function loadZones() {
  try {
    if(locationsData.length === 0) await loadLocations();
    const res = await axios.get('/api/admin/zones');
    zonesData = res.data;
    renderZones();
  } catch(e) {}
}

// ================= RENDERERS =================
function updateLocationDropdown() {
  const select = document.getElementById('zone-location');
  select.innerHTML = '<option value="">-- Pilih Gedung Induk --</option>';
  locationsData.forEach(loc => {
    select.innerHTML += `<option value="${loc._id}">${loc.name}</option>`;
  });
}

function renderLocations() {
  let html = '';
  locationsData.forEach(loc => {
    html += `
      <div class="block bg-surface rounded-2xl shadow-xl shadow-slate-200/50 p-5 hover:shadow-2xl transition-shadow border border-surface-container-high relative overflow-hidden" id="row-loc-${loc._id}">
        <div class="flex justify-between items-start mb-3">
          <div class="pr-4">
            <h3 class="text-headline-md text-on-surface">${loc.name}</h3>
            <p class="text-body-md text-on-surface-variant line-clamp-2 mb-2">${loc.address}</p>
            <div class="flex gap-2">
              <span class="text-label-sm font-semibold bg-surface-dim text-on-surface-variant px-2 py-1 rounded-md">Lat: ${loc.location.coordinates[1]}</span>
              <span class="text-label-sm font-semibold bg-surface-dim text-on-surface-variant px-2 py-1 rounded-md">Lng: ${loc.location.coordinates[0]}</span>
            </div>
          </div>
          <span class="text-label-sm font-semibold bg-primary-container text-on-primary-container px-3 py-1.5 rounded-full shrink-0">Radius ${loc.radius_meters}m</span>
        </div>
        <div class="mt-4 pt-4 border-t border-surface-container-high flex justify-end items-center space-x-2">
          <button onclick="editLocation('${loc._id}')" class="px-5 py-2 bg-surface-dim hover:bg-surface-variant text-on-surface font-bold rounded-full transition-colors text-sm">Ubah</button>
          <button onclick="deleteLocation('${loc._id}')" class="px-5 py-2 bg-error-container hover:bg-error hover:text-white text-error font-bold rounded-full transition-colors text-sm">Hapus</button>
        </div>
      </div>
    `;
  });
  if(!html) html = '<div class="text-center py-12 text-on-surface-variant font-semibold bg-surface rounded-2xl border border-outline-variant border-dashed">Belum ada gedung.</div>';
  document.getElementById('locations-list-body').innerHTML = html;
}

function editLocation(id) {
  const loc = locationsData.find(x => x._id === id);
  if(!loc) return;
  const row = document.getElementById('row-loc-' + id);
  row.innerHTML = `
    <div class="space-y-3 mb-4">
      <input type="text" id="el-name-${id}" value="${loc.name}" class="w-full px-4 py-3 bg-surface-dim border border-outline-variant rounded-xl focus:outline-none focus:ring-2 focus:ring-primary/40 font-bold">
      <input type="text" id="el-addr-${id}" value="${loc.address}" class="w-full px-4 py-3 bg-surface-dim border border-outline-variant rounded-xl focus:outline-none focus:ring-2 focus:ring-primary/40 text-sm">
      <div class="flex items-center gap-3">
        <label class="text-on-surface-variant font-bold text-sm shrink-0">Radius (m):</label>
        <input type="number" id="el-rad-${id}" value="${loc.radius_meters}" class="w-full px-4 py-3 bg-surface-dim border border-outline-variant rounded-xl focus:outline-none focus:ring-2 focus:ring-primary/40 font-mono">
      </div>
    </div>
    <div class="border-t border-surface-container-high pt-4 flex justify-end space-x-2">
      <button onclick="saveLocation('${id}')" class="px-6 py-2 bg-primary text-on-primary font-bold rounded-full shadow-md shadow-blue-500/30 transition-all text-sm">Simpan</button>
      <button onclick="renderLocations()" class="px-6 py-2 bg-surface-dim text-on-surface font-bold rounded-full transition-colors text-sm">Batal</button>
    </div>
  `;
}

function renderZones() {
  let html = '';
  zonesData.forEach(z => {
    const available = z.total_capacity - z.active_reservations - z.active_occupants;
    const isFull = available <= 0;
    
    html += `
      <div class="block bg-surface rounded-2xl shadow-xl shadow-slate-200/50 p-5 hover:shadow-2xl transition-shadow border border-surface-container-high relative overflow-hidden" id="row-zone-${z._id}">
        <div class="text-label-sm font-bold text-on-surface-variant uppercase tracking-wider mb-1">${z.locationId?.name || 'Gedung Dihapus'}</div>
        <div class="flex justify-between items-center mb-4">
          <h3 class="text-headline-md text-on-surface">${z.name} <span class="bg-surface-dim px-2 rounded-md text-sm ml-1 font-mono">${z.floor_level}</span></h3>
          <span class="text-title-lg font-mono font-black text-on-surface">Rp${(z.price_per_hour || 0).toLocaleString('id-ID')}</span>
        </div>
        
        <div class="flex items-center mb-4">
          <span class="px-4 py-1.5 rounded-full font-bold text-sm ${isFull ? 'bg-error-container text-on-error-container' : 'bg-primary-container text-on-primary-container'}">
            Sisa Kuota: ${available} / ${z.total_capacity}
          </span>
        </div>

        <div class="mt-4 pt-4 border-t border-surface-container-high flex flex-wrap justify-end gap-2">
          <button onclick="editZone('${z._id}')" class="px-5 py-2 bg-surface-dim hover:bg-surface-variant text-on-surface font-bold rounded-full transition-colors text-sm">Ubah</button>
          <button onclick="overrideZone('${z._id}')" ${isFull ? 'disabled' : ''} class="${isFull ? 'bg-surface-dim text-outline opacity-50' : 'bg-error-container hover:bg-error hover:text-white text-error'} px-5 py-2 font-bold rounded-full transition-colors text-sm">Tutup</button>
          <button onclick="deleteZone('${z._id}')" class="px-5 py-2 bg-surface hover:bg-error-container text-on-surface-variant hover:text-error font-bold rounded-full transition-colors text-sm border border-outline-variant">Hapus</button>
        </div>
      </div>
    `;
  });
  if(!html) html = '<div class="text-center py-12 text-on-surface-variant font-semibold bg-surface rounded-2xl border border-outline-variant border-dashed">Belum ada zona.</div>';
  document.getElementById('zones-list-body').innerHTML = html;
}

function editZone(id) {
  const z = zonesData.find(x => x._id === id);
  if(!z) return;
  const row = document.getElementById('row-zone-' + id);
  row.innerHTML = `
    <div class="text-label-sm font-bold text-on-surface-variant uppercase tracking-wider mb-3">${z.locationId?.name} • ${z.name}</div>
    <div class="space-y-3 mb-4">
      <div class="flex items-center gap-3">
        <label class="text-on-surface-variant font-bold text-sm shrink-0 w-20">Kapasitas:</label>
        <input type="number" id="ez-cap-${id}" value="${z.total_capacity}" class="w-full px-4 py-3 bg-surface-dim border border-outline-variant rounded-xl focus:outline-none focus:ring-2 focus:ring-primary/40 font-mono">
      </div>
      <div class="flex items-center gap-3">
        <label class="text-on-surface-variant font-bold text-sm shrink-0 w-20">Tarif (Rp):</label>
        <input type="number" id="ez-price-${id}" value="${z.price_per_hour||0}" class="w-full px-4 py-3 bg-surface-dim border border-outline-variant rounded-xl focus:outline-none focus:ring-2 focus:ring-primary/40 font-mono">
      </div>
    </div>
    <div class="border-t border-surface-container-high pt-4 flex justify-end space-x-2">
      <button onclick="saveZone('${id}')" class="px-6 py-2 bg-primary text-on-primary font-bold rounded-full shadow-md shadow-blue-500/30 transition-all text-sm">Simpan</button>
      <button onclick="renderZones()" class="px-6 py-2 bg-surface-dim text-on-surface font-bold rounded-full transition-colors text-sm">Batal</button>
    </div>
  `;
}

async function saveLocation(id) {
  try {
    await axios.put('/api/admin/locations/' + id, {
      name: document.getElementById('el-name-'+id).value,
      address: document.getElementById('el-addr-'+id).value,
      radius_meters: document.getElementById('el-rad-'+id).value
    });
    loadLocations();
  } catch(e) { alert("Gagal menyimpan."); }
}

async function deleteLocation(id) {
  if(confirm("Yakin menghapus Gedung ini? Seluruh data Zona di dalamnya akan ikut terhapus!")) {
    try {
      await axios.delete('/api/admin/locations/' + id);
      loadLocations();
      if(!document.getElementById('tab-zones').classList.contains('hidden')) loadZones();
    } catch(e) { alert("Gagal menghapus."); }
  }
}

async function createLocation() {
  const data = {
    name: document.getElementById('loc-name').value,
    address: document.getElementById('loc-address').value,
    lat: document.getElementById('loc-lat').value,
    lng: document.getElementById('loc-lng').value,
    radius_meters: document.getElementById('loc-radius').value || 5000
  };
  if(!data.name || !data.lat || !data.lng) return alert("Peringatan: Nama dan Koordinat wajib diisi!");
  try {
    await axios.post('/api/admin/locations', data);
    ['loc-name', 'loc-address', 'loc-lat', 'loc-lng', 'loc-radius'].forEach(id => document.getElementById(id).value = '');
    loadLocations();
  } catch(e) { alert("Gagal menyimpan gedung."); }
}

async function createZone() {
  const data = {
    locationId: document.getElementById('zone-location').value,
    name: document.getElementById('zone-name').value,
    floor_level: document.getElementById('zone-floor').value,
    total_capacity: document.getElementById('zone-cap').value,
    price_per_hour: document.getElementById('zone-price').value
  };
  if(!data.locationId || !data.name) return alert("Peringatan: Gedung Induk dan Nama Zona wajib dipilih!");
  try {
    await axios.post('/api/admin/zones', data);
    ['zone-name', 'zone-floor', 'zone-cap', 'zone-price'].forEach(id => document.getElementById(id).value = '');
    loadZones();
  } catch(e) { alert("Gagal menyimpan zona."); }
}

async function saveZone(id) {
  try {
    await axios.put('/api/admin/zones/' + id, {
      total_capacity: document.getElementById('ez-cap-'+id).value,
      price_per_hour: document.getElementById('ez-price-'+id).value
    });
    loadZones();
  } catch(e) { alert("Gagal menyimpan."); }
}

async function deleteZone(id) {
  if(confirm("Yakin menghapus Zona ini secara permanen?")) {
    try {
      await axios.delete('/api/admin/zones/' + id);
      loadZones();
    } catch(e) { alert("Gagal menghapus."); }
  }
}

async function overrideZone(id) {
  if(confirm("PERINGATAN: Aksi ini akan menutup area (membuat kapasitas jadi 0). Lanjutkan?")) {
    try {
      await axios.post('/api/admin/zones/' + id + '/override');
      loadZones();
    } catch(e) { alert("Gagal menutup paksa zona."); }
  }
}

// ================= INITIALIZATION =================
loadStats();
pollingInterval = setInterval(() => {
  if(!document.getElementById('tab-home').classList.contains('hidden')) loadStats();
}, 10000);

switchTab('tab-home');
</script>
<%- include('../partials/footer') %>
