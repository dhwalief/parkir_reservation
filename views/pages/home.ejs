<%- include('../partials/header') %>

<div class="mb-8">
  <h1 class="text-headline-xl-mobile md:text-headline-xl text-on-background mb-2">Cari Parkir Terdekat</h1>
  <p class="text-body-md text-on-surface-variant">Pesan tempat tanpa ribet, langsung masuk.</p>
</div>

<div class="relative mb-8">
  <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
    <svg class="h-5 w-5 text-outline" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
    </svg>
  </div>
  <input type="text" id="search-input" class="w-full pl-11 pr-4 py-4 bg-surface-dim border border-outline-variant rounded-2xl focus:outline-none focus:ring-2 focus:ring-primary/40 focus:border-primary transition-all text-body-lg" placeholder="Cari gedung atau lokasi...">
</div>

<div id="locations-list" class="space-y-4">
  <div class="flex justify-center items-center h-32">
    <div class="animate-spin rounded-full h-8 w-8 border-4 border-primary border-t-transparent"></div>
  </div>
</div>

<script>
let allLocations = [];

function renderLocations(locations) {
  const listEl = document.getElementById('locations-list');
  let html = '';
  
  if (locations.length === 0) {
     html = `<div class="text-center py-12 text-on-surface-variant bg-surface rounded-2xl border border-dashed border-outline-variant">Gedung tidak ditemukan.</div>`;
  }

  locations.forEach(loc => {
    const distanceBadge = loc.distance !== undefined ? `<span class="text-label-sm font-bold bg-primary-container text-on-primary-container px-3 py-1.5 rounded-full shadow-sm">${loc.distance > 1000 ? (loc.distance / 1000).toFixed(1) + ' km' : Math.round(loc.distance) + ' m'}</span>` : '';
    html += `
      <a href="/building/${loc._id}" class="block bg-surface rounded-3xl shadow-xl shadow-slate-200/50 p-5 hover:shadow-2xl transition-shadow border border-surface-container-high relative overflow-hidden group">
        <div class="flex justify-between items-start mb-3">
          <div class="pr-4">
            <h3 class="text-headline-md text-on-surface group-hover:text-primary transition-colors">${loc.name}</h3>
            <p class="text-body-md text-on-surface-variant line-clamp-1">${loc.address}</p>
          </div>
          ${distanceBadge}
        </div>
        <div class="mt-4 pt-4 border-t border-surface-container-high flex justify-between items-center">
          <span class="text-body-md text-on-surface-variant font-bold">Kapasitas Global:</span>
          <span class="text-headline-md font-black ${loc.total_capacity > 0 ? 'text-secondary' : 'text-error'}">${loc.total_capacity || '0'} Unit</span>
        </div>
      </a>
    `;
  });
  listEl.innerHTML = html;
}

function handleSearch(e) {
  const query = e.target.value.toLowerCase();
  const filtered = allLocations.filter(loc => 
    loc.name.toLowerCase().includes(query) || 
    loc.address.toLowerCase().includes(query)
  );
  renderLocations(filtered);
}

async function initHome() {
  let lat = null, lng = null;
  const listEl = document.getElementById('locations-list');
  
  // Tampilkan status pencarian lokasi
  listEl.innerHTML = `
    <div class="flex flex-col justify-center items-center h-32 text-on-surface-variant">
      <div class="animate-spin rounded-full h-8 w-8 border-4 border-primary border-t-transparent mb-4"></div>
      <p id="geo-status" class="text-sm font-bold animate-pulse">📍 Mendeteksi lokasi Anda...</p>
    </div>
  `;

  try {
    const position = await new Promise((resolve, reject) => {
      if (!navigator.geolocation) return reject(new Error('Geolocation not supported'));
      const timer = setTimeout(() => reject(new Error('Prompt timeout')), 6000);
      navigator.geolocation.getCurrentPosition(
        (pos) => { clearTimeout(timer); resolve(pos); },
        (err) => { clearTimeout(timer); reject(err); },
        { enableHighAccuracy: true, timeout: 6000, maximumAge: 0 }
      );
    });
    lat = position.coords.latitude;
    lng = position.coords.longitude;
  } catch (e) {
    console.warn("Geolocation skipped or denied:", e);
    // Tampilkan pesan error sementara sebelum memuat semua data
    const statusEl = document.getElementById('geo-status');
    if (statusEl) {
      statusEl.innerHTML = "⚠️ Gagal mendapatkan lokasi. Menampilkan semua gedung.";
      statusEl.classList.remove('animate-pulse');
      statusEl.classList.add('text-error');
    }
  }

  try {
    const url = (lat && lng) ? `/api/locations?lat=${lat}&lng=${lng}` : `/api/locations`;
    const res = await axios.get(url);
    allLocations = res.data;
    
    // Sort by distance manually if backend doesn't sort it somehow (though $geoNear does)
    if(lat && lng && allLocations.length > 0 && allLocations[0].distance !== undefined) {
       allLocations.sort((a,b) => a.distance - b.distance);
    }

    renderLocations(allLocations);
    
    // Sambungkan input ke event listener setelah data dimuat
    document.getElementById('search-input').addEventListener('input', handleSearch);

  } catch (err) {
    listEl.innerHTML = `<div class="p-4 bg-error-container text-on-error-container font-bold rounded-2xl text-center">Gagal memuat data lokasi dari peladen.</div>`;
  }
}
initHome();
</script>

<%- include('../partials/footer') %>
