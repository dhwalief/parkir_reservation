<%- include('../partials/header') %>

<div class="mb-8">
  <h1 class="text-headline-xl-mobile md:text-headline-xl text-on-background mb-2">Cari Parkir Terdekat</h1>
  <p class="text-body-md text-on-surface-variant">Pesan tempat tanpa ribet, langsung masuk.</p>
</div>

<div class="relative mb-8">
  <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
    <svg class="h-5 w-5 text-outline" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
    </svg>
  </div>
  <input type="text" class="w-full pl-11 pr-4 py-4 bg-surface-dim border border-outline-variant rounded-2xl focus:outline-none focus:ring-2 focus:ring-primary/40 focus:border-primary transition-all text-body-lg" placeholder="Cari gedung atau lokasi...">
</div>

<div id="locations-list" class="space-y-4">
  <div class="flex justify-center items-center h-32">
    <div class="animate-spin rounded-full h-8 w-8 border-4 border-primary border-t-transparent"></div>
  </div>
</div>

<script>
async function initHome() {
  let lat = null, lng = null;
  try {
    const position = await new Promise((resolve, reject) => {
      const timer = setTimeout(() => reject(new Error('Prompt timeout')), 5000);
      navigator.geolocation.getCurrentPosition(
        (pos) => { clearTimeout(timer); resolve(pos); },
        (err) => { clearTimeout(timer); reject(err); },
        { timeout: 5000, maximumAge: 60000 }
      );
    });
    lat = position.coords.latitude;
    lng = position.coords.longitude;
  } catch (e) {
    console.warn("Geolocation skipped or denied.");
  }

  try {
    const url = (lat && lng) ? `/api/locations?lat=${lat}&lng=${lng}` : `/api/locations`;
    const res = await axios.get(url);
    const locations = res.data;
    
    let html = '';
    locations.forEach(loc => {
      const distanceBadge = loc.distance ? `<span class="text-label-sm font-semibold bg-primary-container text-on-primary-container px-2 py-1 rounded-full">${loc.distance > 1000 ? (loc.distance / 1000).toFixed(1) + ' km' : Math.round(loc.distance) + ' m'}</span>` : '';
      html += `
        <a href="/building/${loc._id}" class="block bg-surface rounded-2xl shadow-xl shadow-slate-200/50 p-5 hover:shadow-2xl transition-shadow border border-surface-container-high relative overflow-hidden">
          <div class="flex justify-between items-start mb-3">
            <div>
              <h3 class="text-headline-md text-on-surface">${loc.name}</h3>
              <p class="text-body-md text-on-surface-variant line-clamp-1">${loc.address}</p>
            </div>
            ${distanceBadge}
          </div>
          <div class="mt-4 pt-4 border-t border-surface-container-high flex justify-between items-center">
            <span class="text-body-md text-on-surface-variant">Sisa Kuota Global:</span>
            <span class="text-headline-md ${loc.total_capacity > 0 ? 'text-secondary' : 'text-error'}">${loc.total_capacity || 'N/A'}</span>
          </div>
        </a>
      `;
    });
    const listEl = document.getElementById('locations-list');
    if(listEl) listEl.innerHTML = html;
  } catch (err) {
    const listEl = document.getElementById('locations-list');
    if(listEl) listEl.innerHTML = `<div class="p-4 bg-error-container text-on-error-container rounded-2xl">Gagal memuat data lokasi.</div>`;
  }
}
initHome();
</script>

<%- include('../partials/footer') %>
